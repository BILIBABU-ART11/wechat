page {
  min-height: 100%;
  background: #f5f7fb;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
  font-size: 28rpx;
  letter-spacing: 0;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.page-dark-head {
  background: linear-gradient(180deg, #0f172a 0%, #17324d 360rpx, #f5f7fb 361rpx);
}

.section-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.muted {
  color: #708197;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e5ebf2;
  border-radius: 8rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.05);
}

.primary-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #126d8f;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.secondary-button {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #cbd7e3;
  border-radius: 8rpx;
  color: #17324d;
  background: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.danger-button {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  color: #b42318;
  background: #fff4f2;
  font-size: 28rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d8e1eb;
  border-radius: 8rpx;
  background: #ffffff;
  color: #172033;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 168rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #d8e1eb;
  border-radius: 8rpx;
  background: #ffffff;
  color: #172033;
  font-size: 28rpx;
  line-height: 1.55;
}

.divider {
  height: 1rpx;
  background: #e5ebf2;
}

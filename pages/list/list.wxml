<view class="list-page page">
  <view class="list-head">
    <view>
      <view class="section-title">待办统计</view>
      <view class="list-subtitle">共 {{total}} 条，查看人员待办数量和提醒内容</view>
    </view>
  </view>

  <view class="filter-block">
    <scroll-view scroll-x class="filter-scroll">
      <view class="chip-row">
        <view wx:for="{{categories}}" wx:key="*this" class="filter-chip {{activeCategory == item ? 'active' : ''}}" data-category="{{item}}" bindtap="selectCategory">{{item}}</view>
      </view>
    </scroll-view>
    <view class="score-row">
      <view wx:for="{{scoreFilters}}" wx:key="value" class="score-filter {{activeScore == item.value ? 'active' : ''}}" data-score="{{item.value}}" bindtap="selectScore">{{item.label}}</view>
    </view>
  </view>

  <loading-state wx:if="{{loading}}" text="正在读取待办列表"></loading-state>
  <view wx:elif="{{articles.length}}" class="article-stack">
    <article-card wx:for="{{articles}}" wx:key="id" article="{{item}}" bind:open="openArticle"></article-card>
  </view>
  <empty-state wx:else title="暂无待办" desc="调整筛选条件或下拉刷新"></empty-state>
</view>

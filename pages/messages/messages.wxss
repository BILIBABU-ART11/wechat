.message-head {
  padding: 18rpx 4rpx 22rpx;
}

.message-subtitle {
  margin-top: 8rpx;
  color: #708197;
  font-size: 25rpx;
  line-height: 1.5;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.message-card {
  padding: 28rpx;
  border: 1rpx solid #e5ebf2;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
}

.message-card.unread {
  border-left: 8rpx solid #c15c12;
}

.message-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.message-type {
  color: #172033;
  font-size: 29rpx;
  font-weight: 800;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c15c12;
}

.message-content {
  margin-top: 14rpx;
  color: #526275;
  font-size: 26rpx;
  line-height: 1.55;
}

.message-time {
  margin-top: 18rpx;
  color: #8493a5;
  font-size: 23rpx;
}

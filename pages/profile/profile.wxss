.profile-card {
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #17324d;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 850;
}

.profile-main {
  min-width: 0;
  flex: 1;
}

.nickname {
  color: #172033;
  font-size: 34rpx;
  font-weight: 850;
}

.account {
  margin-top: 10rpx;
  color: #708197;
  font-size: 25rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-card {
  margin-top: 22rpx;
  padding: 10rpx 30rpx;
}

.info-row {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf1f6;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  color: #708197;
  font-size: 26rpx;
}

.info-value {
  max-width: 420rpx;
  color: #172033;
  font-size: 27rpx;
  font-weight: 750;
  text-align: right;
}

.info-value.success {
  color: #167447;
}

.profile-button {
  margin-top: 22rpx;
}
